<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ draft.subject }}</title>
    <style>
      body { font-family: Arial, sans-serif; max-width: 760px; margin: 24px auto; color: #1f2937; line-height: 1.45; }
      .pill { display:inline-block; padding:4px 10px; border-radius: 999px; background:#ecfdf5; color:#065f46; font-size:12px; }
      h1 { margin-bottom: 6px; }
      h2 { margin-top: 22px; }
      ul { padding-left: 20px; }
      .footer { margin-top: 28px; font-size: 12px; color: #6b7280; }
    </style>
  </head>
  <body>
    <div class="pill">County Farm Collective Weekly</div>
    <h1>{{ draft.subject }}</h1>
    <p><em>{{ draft.preheader }}</em></p>
    <p><strong>Week:</strong> {{ draft.week_label }}</p>

    {% for section in draft.sections %}
    <h2>{{ section["title"] }}</h2>

    {% if section["title"] == "NEW THIS WEEK" %}
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:14px;">
      {% for item in section["items"] %}
      {% set parts = item.split(' — ') %}
      {% set title_price = parts[0] %}
      {% set vendor = parts[1] if parts|length > 1 else '' %}
      {% set image = parts[2] if parts|length > 2 else '' %}
      {% set note = '' %}
      {% set link = '' %}
      {% if parts|length > 4 %}
        {% set note = parts[3] %}
        {% set link = parts[4] %}
      {% elif parts|length > 3 %}
        {% if parts[3].startswith('http://') or parts[3].startswith('https://') %}
          {% set link = parts[3] %}
        {% else %}
          {% set note = parts[3] %}
        {% endif %}
      {% endif %}
      {% if link %}<a href="{{ link }}" style="text-decoration:none; color:inherit; display:block;">{% endif %}
      <div style="border:1px solid #d1d5db; border-radius:10px; overflow:hidden; background:#fff;">
        {% if image %}
        <img src="{{ image }}" alt="{{ title_price }}" style="width:100%; height:170px; object-fit:cover; display:block;"/>
        {% endif %}
        <div style="padding:10px;">
          <div style="font-weight:700;">{{ title_price }}</div>
          {% if vendor %}<div style="font-size:13px; color:#374151; margin-top:4px;">{{ vendor }}</div>{% endif %}
          {% if note %}<div style="font-size:12px; color:#6b7280; margin-top:6px;">{{ note }}</div>{% endif %}
        </div>
      </div>
      {% if link %}</a>{% endif %}
      {% endfor %}
    </div>
    {% elif section["title"] == "Main Message" %}
    <div style="background:#f9fafb; border:1px solid #e5e7eb; border-radius:10px; padding:14px;">
      {% for item in section["items"] %}
      <p style="margin:0 0 10px 0;">{{ item }}</p>
      {% endfor %}
    </div>
    {% else %}
    <ul>
      {% for item in section["items"] %}
      <li>{{ item }}</li>
      {% endfor %}
    </ul>
    {% endif %}

    {% endfor %}

    <div class="footer">
      Generated at {{ draft.generated_at_et }}
    </div>
  </body>
</html>
